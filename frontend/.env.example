# KrishiOS Flutter Client Environment Variables Template
# Copy this file to .env and configure for local development or production

# Backend REST API Server Endpoint
SCAN_BASE_URL=http://localhost:8080

# Physical Device Host Override (LAN IP of developer machine for Android physical testing)

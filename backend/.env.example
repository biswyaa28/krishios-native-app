# KrishiOS FastAPI Backend Environment Variables Template
# Copy this file to .env and populate with deployment secrets

# Server Port & Host Configuration
PORT=8080
HOST=0.0.0.0

# CORS Security Configuration (Comma-separated origins or * for dev)
ALLOWED_CORS_ORIGINS=["*"]

# Optional API Bearer Token Authentication (Leave blank for public dev mode)
API_AUTH_TOKEN=your_secure_bearer_token_here

# Directory location for PyTorch & YOLO AI Model Weights
MODEL_DIR=../ai/models

# ==============================================================================
# KrishiOS Master GitIgnore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Heavy Machine Learning Datasets & Training Artifacts
# ------------------------------------------------------------------------------
ai/datasets/
ai/exports/
ai/outputs/runs/
ai/outputs/*.jpg
ai/outputs/*.png
*.zip
*.tar.gz
*.7z
*.rar

# ------------------------------------------------------------------------------
# 2. Environment Variables & Secrets
# ------------------------------------------------------------------------------
.env
.env.local
.env.development
.env.production
*.pem
*.key
*.p12
*.keystore
service-account*.json
google-services.json
GoogleService-Info.plist

# ------------------------------------------------------------------------------
# 3. Python Backend & ML Virtual Environments
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
venv/
.venv/
env/
ENV/
.ipynb_checkpoints/

# ------------------------------------------------------------------------------
# 4. Node.js & Next.js Web Platform
# ------------------------------------------------------------------------------
website/node_modules/
website/.next/
website/out/
node_modules/
.next/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ------------------------------------------------------------------------------
# 5. Flutter & Dart Builds
# ------------------------------------------------------------------------------
frontend/.dart_tool/
frontend/build/
frontend/.pub/
frontend/.pub-cache/
frontend/ephemeral/
.dart_tool/
build/
.pub/
.pub-cache/

# ------------------------------------------------------------------------------
# 6. IDE & Operating System Files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
.idea/
.vscode/
*.suo
*.user
*.userossc
*.sln.docstates
*.swp
*~